# OpenAI — required for n8n workflow generation step
OPENAI_API_KEY=your_openai_api_key_here

# FastAPI settings (RAG_ prefix from pydantic-settings config)
RAG_DOCS_PATH=docs
RAG_CHROMA_PATH=/data/chroma
RAG_COLLECTION_NAME=soporte_registros
RAG_MODEL_NAME=intfloat/multilingual-e5-small
RAG_TOP_K=3
RAG_THRESHOLD=0.80
