# LLM provider: openai (default, required by brief) or anthropic
LLM_PROVIDER=openai

# OpenAI API key -- required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Anthropic API key -- required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# RAG settings (optional -- defaults shown)
RAG_DOCS_PATH=docs
RAG_CHROMA_PATH=/data/chroma
RAG_COLLECTION_NAME=soporte_registros
RAG_MODEL_NAME=intfloat/multilingual-e5-small
RAG_TOP_K=3
RAG_THRESHOLD=0.80
